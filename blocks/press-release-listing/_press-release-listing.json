{
  "definitions": [
    {
      "title": "Press Release Listing",
      "id": "press-release-listing",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "press-release-listing",
              "model": "press-release-listing",
              "filter": "only-press-release-items"
            }
          }
        }
      }
    },
    {
      "title": "Press Release Item",
      "id": "press-release-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "press-release-item",
              "model": "press-release-item"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "press-release-listing",
      "fields": [
        {
          "component": "text",
          "name": "sectionTitle",
          "label": "Section Title (Main Heading)",
          "valueType": "string",
          "defaultValue": "All Releases"
        },
        {
          "component": "text",
          "name": "allReleasesLabel",
          "label": "All Releases Button Text",
          "valueType": "string",
          "defaultValue": "All"
        },
        {
          "component": "text",
          "name": "filterPanelTitle",
          "label": "Filter Sidebar Title",
          "valueType": "string",
          "defaultValue": "Filter by"
        },
        {
          "component": "text",
          "name": "defaultYear",
          "label": "Default Year to Show",
          "valueType": "string",
          "description": "e.g., 2026 (leave empty for all years)"
        },
        {
          "component": "number",
          "name": "itemsPerPage",
          "label": "Items Per Page",
          "valueType": "number",
          "description": "Number of items per page (default: 10)"
        }
      ]
    },
    {
      "id": "press-release-item",
      "itemLabel": "title",
      "fields": [
        {
          "component": "select",
          "name": "category",
          "label": "Business Category",
          "valueType": "string",
          "options": [
            {
              "name": "Corporate",
              "value": "corporate"
            },
            {
              "name": "Airports & Aero Services",
              "value": "airports-aero-services"
            },
            {
              "name": "Energy",
              "value": "energy"
            },
            {
              "name": "Sports",
              "value": "sports"
            },
            {
              "name": "Transport & Urban Infrastructure",
              "value": "transport-urban-infrastructure"
            },
            {
              "name": "Foundation",
              "value": "foundation"
            }
          ]
        },
        {
          "component": "reference",
          "name": "image",
          "label": "Press Release Image",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title / Headline",
          "valueType": "string"
        },
        {
          "component": "textarea",
          "name": "sort_description",
          "label": "Sort Description",
          "valueType": "string",
          "rows": 4
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "valueType": "string"
        },
        {
          "component": "date-time",
          "name": "publishDate",
          "label": "Publish Date",
          "valueType": "string"
        },
        {
          "component": "date-time",
          "name": "lastUpdated",
          "label": "Last Updated Date",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "location",
          "label": "Location",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "contactDetails",
          "label": "Contact Details (JSON)",
          "valueType": "string",
          "description": "JSON array of contact objects. Example: [{\"name\":\"John Doe\",\"role\":\"Head - Communications\",\"email\":\"john@example.com\"},{\"name\":\"Jane Smith\",\"role\":\"PR Manager\",\"email\":\"jane@example.com\"}]"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "only-press-release-items",
      "components": [
        "press-release-item"
      ]
    }
  ]
}