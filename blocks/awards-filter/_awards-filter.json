{
  "definitions": [
    {
      "title": "Awards Filter",
      "id": "awards-filter",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "awards-filter",
              "model": "awards-filter",
              "filter": "only-awards-items"
            }
          }
        }
      }
    },
    {
      "title": "Award Listing Item",
      "id": "award-listing-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "award-listing-item",
              "model": "award-listing-item"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "awards-filter",
      "fields": [
        {
          "component": "text",
          "name": "sectionTitle",
          "label": "Section Title (Main Heading)",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "allAwardsLabel",
          "label": "All Awards Button Text",
          "valueType": "string",
          "defaultValue": "All Awards"
        },
        {
          "component": "text",
          "name": "filterPanelTitle",
          "label": "Filter Sidebar Title",
          "valueType": "string",
          "defaultValue": "Filter by Year and Category"
        },
        {
          "component": "text",
          "name": "defaultYear",
          "label": "Initial Year to Show",
          "valueType": "string",
          "defaultValue": "2026"
        }
      ]
    },
    {
      "id": "award-listing-item",
      "itemLabel": "title",
      "fields": [
        {
          "component": "select",
          "name": "itemType",
          "label": "Item Category",
          "valueType": "string",
          "options": [
            { "name": "Corporate", "value": "corporate" },
            { "name": "Business", "value": "business" }
          ]
        },
        {
          "component": "text",
          "name": "year",
          "label": "Year (e.g. 2026)",
          "valueType": "string"
        },
        {
          "component": "reference",
          "name": "image",
          "label": "Award/Partner Image",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Alt Text"
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title / Heading",
          "valueType": "string"
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description Text",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "only-awards-items",
      "components": ["award-listing-item"]
    }
  ]
}
