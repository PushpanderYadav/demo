{
    "definitions": [
        {
            "title": "Craft Filter",
            "id": "craft-filter",
            "plugins": {
                "xwalk": {
                    "page": {
                        "resourceType": "core/franklin/components/block/v1/block",
                        "template": {
                            "name": "craft-filter",
                            "model": "craft-filter",
                            "filter": "only-craft-items"
                        }
                    }
                }
            }
        },
        {
            "title": "Craft Listing Item",
            "id": "craft-listing-item",
            "plugins": {
                "xwalk": {
                    "page": {
                        "resourceType": "core/franklin/components/block/v1/block/item",
                        "template": {
                            "name": "craft-listing-item",
                            "model": "craft-listing-item"
                        }
                    }
                }
            }
        }
    ],
    "models": [
        {
            "id": "craft-filter",
            "fields": [
                {
                    "component": "text",
                    "name": "sectionTitle",
                    "label": "Section Title (Main Heading)",
                    "valueType": "string"
                },
                {
                    "component": "text",
                    "name": "filterPanelTitle",
                    "label": "Filter Sidebar Title",
                    "valueType": "string",
                    "defaultValue": "Filter by Year and Category"
                }
            ]
        },
        {
            "id": "craft-listing-item",
            "itemLabel": "title",
            "fields": [
                {
                    "component": "select",
                    "name": "itemType",
                    "label": "Item Category",
                    "valueType": "string",
                    "options": [
                        {
                            "name": "Shopping Bags",
                            "value": "shopping-bags"
                        },
                        {
                            "name": "Lunch Bags",
                            "value": "lunch-bags"
                        },
                        {
                            "name": "Sling Bags and Purses",
                            "value": "sling-bags"
                        },
                        {
                            "name": "Home Decor",
                            "value": "home-decor"
                        },
                        {
                            "name": "Office Supplies",
                            "value": "office-supplies"
                        }
                    ]
                },
                {
                    "component": "reference",
                    "name": "image",
                    "label": "Craft Image",
                    "valueType": "string"
                },
                {
                    "component": "text",
                    "name": "imageAlt1",
                    "label": "Alt-Text"
                },
                {
                    "component": "text",
                    "name": "title",
                    "label": "Title / Heading",
                    "valueType": "string"
                },
                {
                    "component": "richtext",
                    "name": "description",
                    "label": "Description Text",
                    "valueType": "string"
                },
                {
                    "component": "text",
                    "name": "link",
                    "label": "Detail Page URL",
                    "valueType": "string"
                }
            ]
        }
    ],
    "filters": [
        {
            "id": "only-craft-items",
            "components": [
                "craft-listing-item"
            ]
        }
    ]
}