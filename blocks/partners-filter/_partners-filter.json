{
  "definitions": [
    {
      "title": "Partners Filter",
      "id": "partners-filter",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "partners-filter",
              "model": "partners-filter",
              "filter": "only-partners-items"
            }
          }
        }
      }
    },
    {
      "title": "Partner Listing Item",
      "id": "partner-listing-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "partner-listing-item",
              "model": "partner-listing-item"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "partners-filter",
      "fields": [
        {
          "component": "text",
          "name": "sectionTitle",
          "label": "Section Title (Main Heading)",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "filterPanelTitle",
          "label": "Filter Sidebar Title",
          "valueType": "string",
          "defaultValue": "Filter by Year and Category"
        }
      ]
    },
    {
      "id": "partner-listing-item",
      "itemLabel": "title",
      "fields": [
        {
          "component": "select",
          "name": "itemType",
          "label": "Item Category",
          "valueType": "string",
          "options": [
            { "name": "Airports", "value": "airports" },
            { "name": "Energy", "value": "energy" },
            { "name": "Transportation", "value": "Transportation " },
            { "name": "GMR Varalakshmi Foundation", "value": "foundation" },
            { "name": "EPC", "value": "epc" }
          ]
        },
        {
          "component": "reference",
          "name": "image",
          "label": "Award/Partner Image",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "imageAlt1",
          "label": "Alt-Text"
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title / Heading",
          "valueType": "string"
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description Text",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "link",
          "label": "Detail Page URL",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "only-partners-items",
      "components": ["partner-listing-item"]
    }
  ]
}
